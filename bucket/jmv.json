{
  "version": "0.1.0",
  "description": "A minimal OpenJDK manager backed by the TUNA Adoptium mirror.",
  "homepage": "https://github.com/fishandsheep/jmv",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/fishandsheep/jmv/releases/download/v0.1.0/jmv_windows_amd64.zip",
      "hash": "5ee5b731b1b4c46ced6fa02defa273a1712a7126655c7f9901fd582ff00e989d"
    },
    "arm64": {
      "url": "https://github.com/fishandsheep/jmv/releases/download/v0.1.0/jmv_windows_arm64.zip",
      "hash": "c3691b0d028ba09013c352bfc02acdcb1674eac829b1c967d24b310370d8f567"
    }
  },
  "bin": "jmv.exe",
  "checkver": {
    "github": "fishandsheep/jmv"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/fishandsheep/jmv/releases/download/v$version/jmv_windows_amd64.zip",
        "hash": {
          "url": "https://github.com/fishandsheep/jmv/releases/download/v$version/checksums.txt",
          "find": "jmv_windows_amd64.zip"
        }
      },
      "arm64": {
        "url": "https://github.com/fishandsheep/jmv/releases/download/v$version/jmv_windows_arm64.zip",
        "hash": {
          "url": "https://github.com/fishandsheep/jmv/releases/download/v$version/checksums.txt",
          "find": "jmv_windows_arm64.zip"
        }
      }
    }
  },
  "persist": [
    "jmv-home"
  ],
  "env_set": {
    "JMV_HOME": "$persist_dir"
  },
  "env_add_path": [
    "$env:JMV_HOME\\shims"
  ],
  "post_install": [
    "Write-Host \"    ___  _____ ______   ___      ___\"",
    "Write-Host \"   |\\  \\|\\   _ \\  _   \\|\\  \\    /  /|\"",
    "Write-Host \"   \\ \\  \\ \\  \\\\\\__\\ \\  \\ \\  \\  /  / /\"",
    "Write-Host \" __ \\ \\  \\ \\  \\|__| \\  \\ \\  \\  \\/  / /\"",
    "Write-Host \"|\\  \\\\_\\  \\ \\  \\    \\ \\  \\ \\    / /\"",
    "Write-Host \"\\ \\________\\ \\__\\    \\ \\__\\ \\__/ /\"",
    "Write-Host \" \\|________|\\|__|     \\|__|\\|__|/    (JDK/JRE MANAGE VERSION)\"",
    "if (!(Test-Path \"$env:JMV_HOME\")) { New-Item -ItemType Directory -Path \"$env:JMV_HOME\" | Out-Null }",
    "if (!(Test-Path \"$env:JMV_HOME\\shims\")) { New-Item -ItemType Directory -Path \"$env:JMV_HOME\\shims\" | Out-Null }",
    "$shimPath = \"$env:JMV_HOME\\shims\"",
    "if ($env:PATH -notlike \"*$shimPath*\") { $env:PATH = \"$shimPath;$env:PATH\" }",
    "$userPath = [Environment]::GetEnvironmentVariable(\"Path\", \"User\")",
    "if ($userPath -notlike \"*$shimPath*\") { [Environment]::SetEnvironmentVariable(\"Path\", \"$shimPath;$userPath\", \"User\") }",
    "Write-Host \"jmv configured JMV_HOME=$env:JMV_HOME\"",
    "Write-Host \"Added $shimPath to current shell PATH and user PATH.\""
  ],
  "post_uninstall": [
    "Write-Host \"Scoop removed jmv. You may delete $env:USERPROFILE\\scoop\\persist\\jmv\\jmv-home if no longer needed.\""
  ]
}
